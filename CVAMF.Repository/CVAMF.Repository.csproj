<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>CVAMF.Repository</PackageId>
    <Version>1.0.0</Version>
    <Authors>Carlos Filho</Authors>
    <Company>CVAMF</Company>
    <Description>Generic Repository Pattern implementation for Entity Framework Core with support for filters, pagination, and multiple primary key types (Guid and Int).</Description>
    <PackageTags>repository;ef-core;entity-framework;generic-repository;pattern</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/CarlosFilho/CVAMFRepository</RepositoryUrl>
    <PackageProjectUrl>https://github.com/CarlosFilho/CVAMFRepository</PackageProjectUrl>
    <PackageIcon>icon.png</PackageIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Include="icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" Version="10.0.0" />
  </ItemGroup>

</Project>
